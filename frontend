<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Secure Token System</title>

<style>
:root {
  --vino: #7a2531;
  --dark: #021223;
  --soft: #b2b4b3;
  --white: #ffffff;
}

body {
  margin: 0;
  font-family: Segoe UI;
  background: var(--dark);
  color: var(--white);
}

header {
  background: var(--vino);
  padding: 20px;
  text-align: center;
}
.wrap {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 20px;
  padding: 20px;
}

.card {
  background: #0b1a2b;
  padding: 15px;
  border-radius: 12px;
}

input, textarea, select, button {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
  border-radius: 6px;
  border: none;
}

button {
  background: var(--vino);
  color: white;
  cursor: pointer;
}

button:hover {
  background: #5c1c26;
}



